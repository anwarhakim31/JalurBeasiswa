
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql" 
 
}


model Pengguna {
  nim          String      @id @unique @db.VarChar(32)
  email        String      @unique
  namaLengkap  String?
  kataSandi    String
  foto         String?
  status       StatusPengguna  @default(Menunggu)
  prodi        String?
  angkatan     Int?
  admin        Boolean     @default(false)

  alternatif   Alternatif[]

  dibuatPada   DateTime @default(now())
  diubahPada   DateTime @updatedAt
}

model Beasiswa {
  id          String   @id @default(cuid())
  kode        String   @unique
  nama        String
  deskripsi   String
  periode     String   // contoh: "2026"
  status       Boolean  @default(true)

  publikasi   Boolean @default(false)
  alternatif  Alternatif[]
  kriteria   Kriteria[]

  hasil Hasil[]

  dibuatPada    DateTime @default(now())
}

model Kriteria {
  id            String   @id @default(cuid())
  kode          String   @unique
  nama          String   // IPK, Penghasilan, dll
  tipe          TipeKriteria   // "benefit" | "cost"
  bobot        Float

  kodeBeasiswa  String
  beasiswa      Beasiswa      @relation(fields: [kodeBeasiswa], references: [kode] ,onDelete: Cascade)

  nilaiAlternatif        NilaiAlternatif[]
  dibuatPada     DateTime @default(now())
}

model Alternatif {
  id            String   @id @default(cuid())
  kode          String   @unique
  kodeBeasiswa  String
  nim           String

  nilaiAlternatif  NilaiAlternatif[]

  pengguna      Pengguna  @relation(fields: [nim], references: [nim],onDelete: Cascade)
  beasiswa      Beasiswa  @relation(fields: [kodeBeasiswa], references: [kode], onDelete: Cascade)

  hasil         Hasil[]

  dibuatPada     DateTime @default(now())
  diubahPada     DateTime @default(now())

  @@unique([nim, kodeBeasiswa]) 
}

model NilaiAlternatif {
  id            String   @id @default(cuid())
  nilai         Float

  kodeAlternatif String
  kodeKriteria    String

  alternatif  Alternatif    @relation(fields: [kodeAlternatif], references: [kode],onDelete: Cascade)
  kriteria      Kriteria    @relation(fields: [kodeKriteria], references: [kode],onDelete: Cascade)

  dibuatPada   DateTime @default(now())
  
  @@unique([kodeAlternatif, kodeKriteria]) // biar tidak double
}

model Hasil {
  id            String @id @default(cuid())
  nilai         Float
  peringkat          Int

  kodeAlternatif String
  kodeBeasiswa    String
  status         StatusHasil @default(Diproses)
  alternatif    Alternatif @relation(fields: [kodeAlternatif], references: [kode],onDelete: Cascade)
  beasiswa      Beasiswa   @relation(fields: [kodeBeasiswa], references: [kode],onDelete: Cascade)

  dibuatPada   DateTime @default(now())

  @@unique([kodeAlternatif, kodeBeasiswa]) // 1 alternatif hanya 1 hasil per beasiswa
}

enum StatusPengguna {
  Diterima
  Menunggu
  Ditolak
}

enum StatusHasil { 
  Diterima
  Ditolak
  Diproses
}

enum  TipeKriteria {
  Keuntungan
  Biaya
}