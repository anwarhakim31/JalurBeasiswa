
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql" 
 
}


model Pengguna{
  nim       String @id @unique @db.VarChar(32)
  email     String @unique
  fullname  String?
  password  String
  photo     String?
  status    UserStatus @default(PENDING)
  prodi     String?
  batch     Int?
  isAdmin   Boolean @default(false)

  alternatif Alternatif[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Beasiswa {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description  String
  period      String   // contoh: "2026"
  isActive    Boolean  @default(true)

  alternatif  Alternatif[]
  kriteria   Kriteria[]

  hasil Hasil[]

  createdAt    DateTime @default(now())
}

model Kriteria {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String   // IPK, Penghasilan, dll
  type          creteriaType   // "benefit" | "cost"
  weight        Float

  beasiswaCode  String
  beasiswa      Beasiswa      @relation(fields: [beasiswaCode], references: [code] ,onDelete: Cascade)

  values        NilaiAlternatif[]
  createdAt     DateTime @default(now())



}

model Alternatif {
  id            String   @id @default(cuid())
  code          String   @unique
  beasiswaCode  String
  nim           String

  values        NilaiAlternatif[]

  pengguna      Pengguna  @relation(fields: [nim], references: [nim],onDelete: Cascade)
  beasiswa      Beasiswa  @relation(fields: [beasiswaCode], references: [code], onDelete: Cascade)

  hasil         Hasil[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  @@unique([nim, beasiswaCode]) 
}

model NilaiAlternatif {
  id            String   @id @default(cuid())
  value         Float

  alternativeCode String
  kriteriaCode    String

  alternatif  Alternatif    @relation(fields: [alternativeCode], references: [code],onDelete: Cascade)
  kriteria      Kriteria    @relation(fields: [kriteriaCode], references: [code],onDelete: Cascade)

  @@unique([alternativeCode, kriteriaCode]) // biar tidak double
}

model Hasil {
  id            String @id @default(cuid())
  score         Float
  rank          Int

  alternativeCode String
  beasiswaCode    String

  alternatif    Alternatif @relation(fields: [alternativeCode], references: [code],onDelete: Cascade)
  beasiswa      Beasiswa   @relation(fields: [beasiswaCode], references: [code],onDelete: Cascade)

  @@unique([alternativeCode, beasiswaCode]) // 1 alternatif hanya 1 hasil per beasiswa
}

enum UserStatus {
  ACCEPT
  PENDING
  REJECTED
}

enum creteriaType {
  BENEFIT
  COST
}